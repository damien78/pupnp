@PACKAGE_INIT@

if(@UPNP_BUILD_SHARED@)
	list(APPEND _ixml_available_components Shared)
endif()

if(@UPNP_BUILD_STATIC@)
	list(APPEND _ixml_available_components Static)
endif()

if(IXML_FIND_COMPONENTS)
	 set(_valid_components
		Shared
		Static)

	foreach(comp IN LISTS IXML_FIND_COMPONENTS)
		if(NOT comp IN_LIST _valid_components)
			set(IXML_FOUND FALSE)
			set(IXML_NOT_FOUND_MESSAGE
				"Unknown component: ${comp}")
			return()
		endif()
	endforeach()
endif()

include(${CMAKE_CURRENT_LIST_DIR}/IXML.cmake)

if(NOT IXML_FIND_COMPONENTS)
	set(IXML_FOUND TRUE)
else()
	foreach(comp IN LISTS IXML_FIND_COMPONENTS)
		list(FIND _ixml_available_components "${comp}" _idx)

		if(_idx EQUAL -1)
			set(IXML_FOUND FALSE)
			set(IXML_NOT_FOUND_MESSAGE
			"Component ${comp} is not available in this build")
		endif()
	endforeach()
endif()

set(IXML_HAVE_SCRIPTSUPPORT @IXML_HAVE_SCRIPTSUPPORT@ CACHE INTERNAL "see.upnpconfig.h")
