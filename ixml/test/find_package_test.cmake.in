cmake_minimum_required(VERSION 3.12...3.31)

project(ixml_add_find_package_test
	LANGUAGES C
	VERSION @IXML_SOVERSION_STRING@)

option(UPNP_BUILD_SHARED "" @UPNP_BUILD_SHARED@)
option(UPNP_BUILD_STATIC "" @UPNP_BUILD_STATIC@)

if(UPNP_BUILD_SHARED)
	find_package(IXML @IXML_SOVERSION_STRING@ CONFIG COMPONENTS Shared REQUIRED)
	add_executable(test_document_shared @PUPNP_SOURCE_DIR@/ixml/test/test_document.c)
	target_link_libraries(test_document_shared IXML::Shared)
endif()

if(UPNP_BUILD_STATIC)
	find_package(IXML @IXML_SOVERSION_STRING@ CONFIG COMPONENTS Static REQUIRED)
	add_executable(test_document_static @PUPNP_SOURCE_DIR@/ixml/test/test_document.c)
	target_link_libraries(test_document_static IXML::Static)
endif()